		"vuetify": "^4.0.2"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^24.12.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vue/tsconfig": "^0.9.0",
		"eslint": "^10.6.0",
		"eslint-config-vuetify": "^4.7.2",
		"gh-pages": "^6.3.0",
		"npm-run-all2": "^8.0.4",
		"sass-embedded": "^1.98.0",
		"tailwindcss": "^4.2.1",
		"typescript": "~5.9.3",
		"unplugin-fonts": "^1.4.0",
		"vite": "^8.0.0",
		"vite-plugin-vuetify": "^2.1.3",
